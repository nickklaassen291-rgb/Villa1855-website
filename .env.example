# Villa 1855 - Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# GOOGLE SHEETS (Aanmeldingen opslaan)
# ===========================================
# 1. Ga naar Google Cloud Console: https://console.cloud.google.com
# 2. Maak een nieuw project of selecteer een bestaand project
# 3. Enable de Google Sheets API
# 4. Ga naar IAM & Admin > Service Accounts
# 5. Maak een nieuwe Service Account aan
# 6. Maak een JSON key aan en download deze
# 7. Kopieer de HELE inhoud van het JSON bestand hieronder (als één regel)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project",...}

# De ID van je Google Sheet (te vinden in de URL)
# Voorbeeld URL: https://docs.google.com/spreadsheets/d/1ABC123xyz/edit
# Dan is de ID: 1ABC123xyz
GOOGLE_SHEET_ID=your-spreadsheet-id

# BELANGRIJK: Deel de Google Sheet met het e-mailadres van de Service Account
# (te vinden in de JSON key onder "client_email")

# ===========================================
# META PIXEL (Facebook/Instagram Tracking)
# ===========================================
# Get your Pixel ID from Meta Business Suite
NEXT_PUBLIC_META_PIXEL_ID=123456789

# ===========================================
# GOOGLE ANALYTICS (Optional)
# ===========================================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
